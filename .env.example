# Copy this file to `.env` and fill in real values.
# Do not commit your real `.env`.

# Required for Spotify auth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/spotify/callback
SOTD_CRYPTO_BASE64_KEY=
SOTD_UPSTREAM_AUTH_SHARED_SECRET=

# Optional upstream auth controls
SOTD_UPSTREAM_AUTH_ENABLED=false
SOTD_UPSTREAM_AUTH_CLOCK_SKEW=PT30S
SOTD_UPSTREAM_AUTH_QUERY_PARAMETER=upstreamAuth
SOTD_UPSTREAM_AUTH_HEADER=X-SOTD-UPSTREAM-AUTH

# Optional database overrides
SOTD_DATABASE_URL=jdbc:postgresql://localhost:5432/sotd
SOTD_DATABASE_USERNAME=sotd
SOTD_DATABASE_PASSWORD=sotd
SOTD_DATABASE_POOL_SIZE=10

# Optional Spotify API overrides
SPOTIFY_BASE_URL=https://api.spotify.com/v1
SPOTIFY_ACCOUNTS_BASE_URL=https://accounts.spotify.com

# Optional Spotify auth settings
SPOTIFY_SCOPE_1=user-read-recently-played
SPOTIFY_SCOPE_2=user-read-playback-state
SPOTIFY_SCOPE_3=user-read-currently-playing
SPOTIFY_SCOPE_4=user-read-private
SPOTIFY_SHOW_DIALOG=false
SPOTIFY_AUTH_STATE_TTL=PT10M

# Optional polling defaults
SPOTIFY_RECENTLY_PLAYED_INTERVAL=PT2M
SPOTIFY_CURRENT_PLAYBACK_INTERVAL=PT20S

# Optional logging defaults
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SOTD=INFO

# Optional profiles
# Use `--spring.profiles.active=filelog` for local rolling file logs.
# Use `--spring.profiles.active=container` for structured JSON console logs in containers.
